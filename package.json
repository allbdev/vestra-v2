{
  "name": "vestra",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "deploy:api": "flyctl deploy . --config apps/api/fly.toml --dockerfile apps/api/Dockerfile",
    "deploy:api:logs": "flyctl logs -a vestra-api"
  },
  "devDependencies": {
    "turbo": "^2.5.6",
    "typescript": "^5.9.3"
  }
}
