# Dashboard env — optional for local dev.
# Vite dev proxies /api → http://localhost:3001 (see vite.config.ts),
# so VITE_API_URL is unset in dev and the dashboard talks via /api/v1.
#
# Set this only for production builds, or to point at a non-local API.
# VITE_API_URL="https://api.vestra.app/api/v1"
#
# Reminder: anything VITE_*-prefixed is shipped to the browser bundle.
# Never put secrets here.
