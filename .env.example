# Database (reuses existing Postgres volume from vestra_old)
DATABASE_URL="postgresql://user:password@localhost:5432/vestra"

# Auth
JWT_ACCESS_SECRET="change-me-access"
JWT_REFRESH_SECRET="change-me-refresh"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="30d"

# URLs (CORS allowlist + cross-app links)
APP_URL="http://localhost:3000"
API_URL="http://localhost:3001"
DASHBOARD_URL="http://localhost:5173"
MARKETING_URL="http://localhost:3000"

# Email (Resend)
RESEND_API_KEY=""
EMAIL_FROM="Vestra <noreply@example.com>"
EMAIL_TO="contact@example.com"

# Cron
CRON_SECRET="change-me-cron"
